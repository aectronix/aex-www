<!-- SLIDING -->

<script>
document.addEventListener('DOMContentLoaded', () => {
	const track = document.querySelector('.services__track') as HTMLElement;
	const cards = document.querySelectorAll('.service-card');
	const prevBtn = document.querySelector('.services__nav-btn[aria-label="Previous slide"]') as HTMLButtonElement;
	const nextBtn = document.querySelector('.services__nav-btn[aria-label="Next slide"]') as HTMLButtonElement;
	const indicatorsContainer = document.querySelector('.services__indicators') as HTMLElement;

	if (!track || cards.length === 0 || !indicatorsContainer) return;

	// make slashes
	indicatorsContainer.innerHTML = '';
	cards.forEach((_, i) => {
		const slash = document.createElement('button');
		slash.type = 'button';
		slash.className = 'services__indicator';
		slash.textContent = '/';
		slash.setAttribute('aria-label', `Go to slide ${i + 1}`);
		indicatorsContainer.appendChild(slash);
	});

	const indicators = document.querySelectorAll('.services__indicator');
	let currentIndex = 0;
	let maxIndex = 0;
	let autoSlideTimer: ReturnType<typeof setInterval>;

	function updateSlider() {
		const cardWidth = (cards[0] as HTMLElement).offsetWidth;
		const gap = 40; 
		const step = cardWidth + gap;

		const containerWidth = track.parentElement!.offsetWidth;
		const visibleCards = Math.floor((containerWidth + gap) / step) || 1;
		maxIndex = Math.max(0, cards.length - visibleCards);

		if (currentIndex > maxIndex) currentIndex = maxIndex;
		if (currentIndex < 0) currentIndex = 0;

		track.style.transform = `translateX(-${currentIndex * step}px)`;

		// highlight slashes
		indicators.forEach((slash, index) => {
			if (index < currentIndex + visibleCards) {
				slash.classList.add('services__indicator--active');
			} else {
				slash.classList.remove('services__indicator--active');
			}
		});

		if (prevBtn) {
			prevBtn.style.opacity = currentIndex === 0 ? '0.3' : '1';
			prevBtn.style.cursor = currentIndex === 0 ? 'default' : 'pointer';
		}
		if (nextBtn) {
			nextBtn.style.opacity = currentIndex === maxIndex ? '0.3' : '1';
			nextBtn.style.cursor = currentIndex === maxIndex ? 'default' : 'pointer';
		}
	}

	function startAutoSlide() {
		clearInterval(autoSlideTimer);
		autoSlideTimer = setInterval(() => {
			if (currentIndex === maxIndex) {
				currentIndex = 0;
			} else {
				currentIndex += 3;
				if (currentIndex > maxIndex) currentIndex = maxIndex;
			}
			updateSlider();
		}, 7500);
	}

	prevBtn?.addEventListener('click', () => {
		if (currentIndex > 0) {
			currentIndex--;
			updateSlider();
			startAutoSlide();
		}
	});

	nextBtn?.addEventListener('click', () => {
		const cardWidth = (cards[0] as HTMLElement).offsetWidth;
		const visibleCards = Math.floor((track.parentElement!.offsetWidth + 40) / (cardWidth + 40)) || 1;
		const maxIndex = Math.max(0, cards.length - visibleCards);

		if (currentIndex < maxIndex) {
			currentIndex++;
			updateSlider();
			startAutoSlide();
		}
	});

	// click slashes
	indicators.forEach((slash, index) => {
		slash.addEventListener('click', () => {
			const cardWidth = (cards[0] as HTMLElement).offsetWidth;
			const visibleCards = Math.floor((track.parentElement!.offsetWidth + 40) / (cardWidth + 40)) || 1;
			// calc the slides
			const targetIndex = index - visibleCards + 1;
			// safe boxes
			currentIndex = Math.max(0, Math.min(targetIndex, maxIndex));
			updateSlider();
			startAutoSlide();
		});
	});

	// pause on hover
	track.addEventListener('mouseenter', () => clearInterval(autoSlideTimer));
	track.addEventListener('mouseleave', startAutoSlide);

	window.addEventListener('resize', updateSlider);
	
	updateSlider();
	startAutoSlide();
});
</script>