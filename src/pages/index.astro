---
import '../styles/global.css';
import Logo from '../components/aex_logo.astro';
import LogoText from '../components/aex_logo_text.astro';
import { Image } from 'astro:assets';
import ItemMenu from '../components/item_menu.astro';
import ItemArrow from '../components/item_arrow.astro';
import HeroImage from '../assets/aex_hero_cover.png';
const pageTitle = "aectronix";
---

<html lang="en" class="www">

	<head>
		<title>{pageTitle}</title>
		<meta charset="utf-8" />
		<meta name="description" content="aectronix – we provide bim, vdc and digitalization to aeco sector" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>

	<body class="main bg-00-lightgrey">

		<header class="header">
			<div class="header__inner container">
				<a href="#" class="header__brand" aria-label="aectronix home"><Logo /><LogoText /></a>
				<nav class="nav header__nav">
					<ul class="nav__list">
						<li class="nav__item"><a class="nav__link" href="#">home</a></li>
						<li class="nav__item"><a class="nav__link" href="#">services</a></li>
						<li class="nav__item"><a class="nav__link" href="#">about</a></li>
						<li class="nav__item"><a class="nav__link" href="#">blog</a></li>
						<li class="nav__item nav__item--lang"><a class="nav__link" href="#">en</a></li>
					</ul>
					<button type="button" class="header__burger" aria-label="Open menu">
						<ItemMenu />
					</button>
				</nav>
			</div>
		</header>

		<main>

			<section class="hero">
				<div class="hero__inner container">
					<div class="hero__layout">
						<div class="hero__motto">
							<h1 class="hero__headline">
								We&nbsp;are&nbsp;making construction&nbsp;digital again.&nbsp;Whatever.
							</h1>
						</div>
						<div class="hero__cta-wrapper">
							<a href="#" class="hero__cta group" aria-label="Contact Us">
								<span class="hero__cta-text">Contact Us</span>
								<span class="hero__cta-icon" aria-hidden="true"><ItemArrow /></span>
							</a>
						</div>
						<div class="hero__image-wrapper">
							<Image 
								src={HeroImage} 
								alt="Building Information Manager with a laptop" 
								class="hero__image" 
							/>
						</div>
							<div class="hero__description">
								<p class="hero__description-text">
									Utilizing BIM, VDC and digital approach, we help to transform<br class="hidden md:block" />
									AECO sector for better efficiency & outcomes
								</p>
							</div>
					</div>
				</div>
			</section>

			<section class="services">
				<div class="services__inner container">
					<div class="services__grid">

						<div class="services__intro">
							<div class="services__intro-line"></div>
							<h2 class="services__intro-title">Our Services</h2>
							<p class="services__intro-text">
								We could provide a wide range of BIM, VDC, IT and other digital services to satisfy client any needs and goals.
							</p>
							<a href="#" class="services__intro-link">&gt; see all_</a>
						</div>

						<article class="service-card group">
							<div class="service-card__tag">BIM</div>

							<div class="service-card__content">
								<h3 class="service-card__title">BIM Consulting & Standards</h3>
								<p class="service-card__desc">
									We support ongoing projects by establishing and maintaining digital collaborative workflows among involved parties.
								</p>
							</div>

							<a href="#" class="service-card__link">
								<span class="service-card__link-default">&gt; details_&nbsp;</span>
								<span class="service-card__link-hover">&gt; explore_</span>
							</a>

							<div class="service-card__cutout">
								<button class="service-card__action" aria-label="Explore BIM Consulting">
									<ItemArrow />
								</button>
							</div>
						</article>

						<article class="service-card group">
							<div class="service-card__tag">BIM</div>

							<div class="service-card__content">
								<h3 class="service-card__title">BIM Management & Coordination</h3>
								<p class="service-card__desc">
									We support ongoing projects by establishing and maintaining digital collaborative workflows among involved parties.
								</p>
							</div>

							<a href="#" class="service-card__link">
								<span class="service-card__link-default">&gt; details_&nbsp;</span>
								<span class="service-card__link-hover">&gt; explore_</span>
							</a>

							<div class="service-card__cutout">
								<button class="service-card__action" aria-label="Explore BIM Consulting">
									<ItemArrow />
								</button>
							</div>
						</article>

						<article class="service-card group">
							<div class="service-card__tag">DEV</div>

							<div class="service-card__content">
								<h3 class="service-card__title">Development & Automation</h3>
								<p class="service-card__desc">
									We support ongoing projects by establishing and maintaining digital collaborative workflows among involved parties.
								</p>
							</div>

							<a href="#" class="service-card__link">
								<span class="service-card__link-default">&gt; details_&nbsp;</span>
								<span class="service-card__link-hover">&gt; explore_</span>
							</a>

							<div class="service-card__cutout">
								<button class="service-card__action" aria-label="Explore BIM Consulting">
									<ItemArrow />
								</button>
							</div>
						</article>

					</div>
				</div>
			</section>

		</main>

	</body>

</html>