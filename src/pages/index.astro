---
import '../styles/global.css';
import Logo from '../components/aex_logo.astro';
import LogoText from '../components/aex_logo_text.astro';
import { Image } from 'astro:assets';
import ItemMenu from '../components/item_menu.astro';
import ItemArrow from '../components/item_arrow.astro';
import HeroImage from '../assets/aex_hero_cover.png';
import Services from '../components/block_services.astro';

const pageTitle = "aectronix";
---

<html lang="en" class="www">

	<head>
		<title>{pageTitle}</title>
		<meta charset="utf-8" />
		<meta name="description" content="aectronix – we provide bim, vdc and digitalization to aeco sector" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>

	<body class="bg-00-lightgrey">

		<header class="header">
			<div class="header__inner container">
				<a href="#" class="header__brand" aria-label="aectronix home"><Logo /><LogoText /></a>
				<nav class="nav header__nav">
					<ul class="nav__list">
						<li class="nav__item"><a class="nav__link" href="#">home</a></li>
						<li class="nav__item"><a class="nav__link" href="#">services</a></li>
						<li class="nav__item"><a class="nav__link" href="#">about</a></li>
						<li class="nav__item"><a class="nav__link" href="#">blog</a></li>
						<li class="nav__item nav__item--lang"><a class="nav__link" href="#">en</a></li>
					</ul>
					<button type="button" class="header__burger" aria-label="Open menu">
						<ItemMenu />
					</button>
				</nav>
			</div>
		</header>

		<main>

			<section class="hero">
				<div class="hero__inner container">
					<div class="hero__layout">
						<div class="hero__motto">
							<h1 class="hero__headline">
								We&nbsp;are&nbsp;making construction&nbsp;digital again.&nbsp;Whatever.
							</h1>
						</div>
						<div class="hero__cta-wrapper">
							<a href="#" class="hero__cta group" aria-label="Contact Us">
								<span class="hero__cta-text">Contact Us</span>
								<span class="hero__cta-icon" aria-hidden="true"><ItemArrow /></span>
							</a>
						</div>
						<div class="hero__image-wrapper">
							<Image 
								src={HeroImage} 
								alt="Building Information Manager with a laptop" 
								class="hero__image" 
							/>
						</div>
							<div class="hero__description">
								<p class="hero__description-text">
									Utilizing BIM, VDC and digital approach, we help to transform<br class="hidden md:block" />
									AECO sector for better efficiency & outcomes
								</p>
							</div>
					</div>
				</div>
			</section>

			<Services />

		</main>

	</body>

</html>